# Copy to .env and fill in real values.
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Base64 32-byte key for Fernet (secrets at rest). Generate with:
#   python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
MASTER_KEY=

# JWT
JWT_SECRET=change-me-32-bytes-minimum
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# Database
DATABASE_URL=sqlite:///./data/app.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_TO_STDOUT=true

# Uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_IMAGE_MB=10
UPLOAD_MAX_FILE_MB=25

# Rate limits (requests per window)
RATE_LIMIT_CHAT_PER_MIN=60
RATE_LIMIT_CHAT_PER_HOUR=1000
RATE_LIMIT_MUTATE_PER_MIN=30

# Sandbox
SANDBOX_PYTHON=python
SANDBOX_ALLOW_PRIVATE_NET=false
